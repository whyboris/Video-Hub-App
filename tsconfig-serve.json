{
  "compilerOptions": {
    "noImplicitAny": false,
    "strictNullChecks": false,
    "declaration": false,
    "experimentalDecorators": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "",
    "lib": [
      "es2023",
      "dom"
    ],
    "module": "node16",
    "moduleResolution": "nodenext",
    "sourceMap": true,
    "target": "es6",
    "typeRoots": [
      "node_modules/@types"
    ]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "main.ts"
  ]
}
